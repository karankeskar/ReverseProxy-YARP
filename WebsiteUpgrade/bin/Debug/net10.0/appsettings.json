{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
   "ReverseProxy":{
    "Routes":{
      "random-route":{
        "ClusterId":"randomCluster",
        "Match":{
          "Path":"/random"
        },
        "Transforms":[{
          "PathRemovePrefix":"/random"
        }]
      },
      "catch-all":{
        "ClusterId":"catchallCluster",
        "Match":{
          "Path":"/{**catch-all}"
        }
      }
    },
    "Clusters":{
      "randomCluster":{
        "Destinations":{
          "Blazor":{
            "Address":"https://karankeskar.com/about"
          },
          "CSharpMasterCourse":{
            "Address":"https://karankeskar.com/portfolio"
          },
          "GithubAccelerate":{
            "Address":"https://karankeskar.com/contact"
          }
        }
      },
      "catchallCluster":{
        "Destinations":{
          "ImKaran":{
            "Address":"https://karankeskar.com/"
          }
        }
      }
    }
  } 
}
